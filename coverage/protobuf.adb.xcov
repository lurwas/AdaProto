 702 .:    function Parse_From_Stream
 703 .:      (Stream : not null access Ada.Streams.Root_Stream_Type'Class;
 704 .:       Length : Natural) return Parsed_Field_Vectors.Vector is
 705 .:    begin
 706 +:       if Length = 0 then
 707 -:          return Parse_From_String ("");
 708 .:       end if;
 709 .: 
 710 .:       declare
 711 +:          Bytes : Ada.Streams.Stream_Element_Array
 712 +:            (1 .. Ada.Streams.Stream_Element_Offset (Length));
 713 +:          Last  : Ada.Streams.Stream_Element_Offset := 0;
 714 +:          Read_Up_To : Ada.Streams.Stream_Element_Offset := 0;
 715 .:       begin
 716 +:          while Read_Up_To < Bytes'Last loop
 717 +:             Ada.Streams.Read
 718 +:               (Stream.all,
 719 +:                Bytes (Read_Up_To + 1 .. Bytes'Last),
 720 +:                Last);
 721 +:             if Last < Read_Up_To + 1 then
 722 -:                raise Parse_Error with "truncated stream input";
 723 .:             end if;
 724 +:             Read_Up_To := Last;
 725 .:          end loop;
 726 .: 
 727 .:          declare
 728 +:             Data : String (1 .. Length);
 729 .:          begin
 730 +:             for I in Data'Range loop
 731 +:                Data (I) :=
 732 +:                  Character'Val
 733 +:                    (Bytes (Ada.Streams.Stream_Element_Offset (I)));
 734 .:             end loop;
 735 +:             return Parse_From_String (Data);
 736 .:          end;
 737 .:       end;
 738 .:    end Parse_From_Stream;
