 740 .:    function Check_Kind (Field : Parsed_Field; Expected : Wire_Type) return Parsed_Field is
 741 .:    begin
 742 +:       if Field.Kind /= Expected then
 743 +:          raise Parse_Error with "wire type mismatch";
 744 .:       end if;
 745 +:       return Field;
 746 .:    end Check_Kind;
