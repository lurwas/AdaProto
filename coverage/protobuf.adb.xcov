 521 +:       while Cursor <= Bytes'Last loop
 522 +:          Values.Append (ZigZag_Decode_64 (Decode_Varint (Bytes, Cursor)));
 523 .:       end loop;
 524 +:       return Result : Int64_Array (1 .. Integer (Values.Length)) do
 525 +:          for I in Result'Range loop
 526 +:             Result (I) := Values (Natural (I - Result'First));
 527 .:          end loop;
 528 .:       end return;
 529 .:    end Decode_Packed_SInt64;
