 629 .:    function Parse_From_String (Data : String) return Parsed_Field_Vectors.Vector is
 630 +:       Result : Parsed_Field_Vectors.Vector;
 631 +:       Cursor : Natural := Data'First;
 632 .:    begin
 633 +:       while Cursor <= Data'Last loop
 634 .:          declare
 635 +:             Tag : constant Unsigned_64 := Decode_Varint (Data, Cursor);
 636 +:             Number : constant Unsigned_64 := Shift_Right (Tag, 3);
 637 +:             Kind_Code : constant Unsigned_64 := Tag and 7;
 638 .:          begin
 639 +:             if Number = 0 or else Number > Unsigned_64 (Field_Number'Last) then
 640 +:                raise Parse_Error with "invalid field number";
 641 .:             end if;
 642 .: 
 643 +:             case Kind_Code is
 644 .:                when 0 =>
 645 +:                   Result.Append
 646 +:                     (Parsed_Field'
 647 +:                        (Kind => Varint_Wire,
 648 +:                         Number => Field_Number (Number),
 649 +:                         Varint_Value => Decode_Varint (Data, Cursor)));
 650 .:                when 1 =>
 651 +:                   Result.Append
 652 +:                     (Parsed_Field'
 653 +:                        (Kind => Fixed64_Wire,
 654 +:                         Number => Field_Number (Number),
 655 +:                         Fixed64_Value => Decode_Fixed64 (Data, Cursor)));
 656 .:                when 2 =>
 657 .:                   declare
 658 +:                      Length : constant Unsigned_64 := Decode_Varint (Data, Cursor);
 659 +:                      Last : Natural;
 660 .:                   begin
 661 +:                      if Length > Unsigned_64 (Natural'Last) then
 662 -:                         raise Parse_Error with "length too large";
 663 .:                      end if;
 664 +:                      Last := Cursor + Natural (Length) - 1;
 665 +:                      if Natural (Length) = 0 then
 666 +:                         Result.Append
 667 +:                           (Parsed_Field'
 668 +:                              (Kind => Length_Delimited_Wire,
 669 +:                               Number => Field_Number (Number),
 670 +:                               Bytes_Value => To_Unbounded_String ("")));
 671 .:                      else
 672 +:                         if Last > Data'Last then
 673 +:                            raise Parse_Error with "truncated length-delimited field";
 674 .:                         end if;
 675 +:                         Result.Append
 676 +:                           (Parsed_Field'
 677 +:                              (Kind => Length_Delimited_Wire,
 678 +:                               Number => Field_Number (Number),
 679 +:                               Bytes_Value => To_Unbounded_String (Data (Cursor .. Last))));
 680 +:                         Cursor := Last + 1;
 681 .:                      end if;
 682 .:                   end;
 683 .:                when 5 =>
 684 +:                   Result.Append
 685 +:                     (Parsed_Field'
 686 +:                        (Kind => Fixed32_Wire,
 687 +:                         Number => Field_Number (Number),
 688 +:                         Fixed32_Value => Decode_Fixed32 (Data, Cursor)));
 689 .:                when others =>
 690 +:                   raise Parse_Error with "unsupported wire type";
 691 .:             end case;
 692 .:          end;
 693 .:       end loop;
 694 +:       return Result;
 695 .:    end Parse_From_String;
 696 .: 
 697 .:    function Deserialize_From_String (Data : String) return Parsed_Field_Vectors.Vector is
 698 .:    begin
 699 +:       return Parse_From_String (Data);
 700 .:    end Deserialize_From_String;
