1074 +:          AUnit.Test_Suites.Add_Test (Registered_Suite, New_Case ("fixture all types", Test_Fixture_All_Types_Compatibility'Access));
1075 +:          AUnit.Test_Suites.Add_Test (Registered_Suite, New_Case ("golden match", Test_Ada_Encoding_Matches_Golden'Access));
1076 +:          AUnit.Test_Suites.Add_Test (Registered_Suite, New_Case ("fixture advanced types", Test_Fixture_Advanced_Types_Compatibility'Access));
1077 +:          AUnit.Test_Suites.Add_Test (Registered_Suite, New_Case ("advanced golden match", Test_Ada_Encoding_Matches_Advanced_Golden'Access));
1078 +:          AUnit.Test_Suites.Add_Test (Registered_Suite, New_Case ("unknown fields stability", Test_Unknown_Fields_Stability'Access));
