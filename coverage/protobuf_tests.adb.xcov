 610 .:    procedure Test_Unknown_Fields_Stability is
 611 +:       B : Protobuf.Message_Buffer;
 612 +:       Parsed : Protobuf.Parsed_Field_Vectors.Vector;
 613 .:    begin
 614 +:       Protobuf.Add_Int32 (B, 1, 10);
 615 +:       Protobuf.Add_Fixed32 (B, 19_000, 16#DEAD_BEEF#);
 616 +:       Protobuf.Add_String (B, 2, "known");
 617 +:       Protobuf.Add_UInt64 (B, 29_000, 123456789);
 618 +:       Parsed := Protobuf.Parse_From_String (Protobuf.To_String (B));
 619 +:       Assert (Protobuf.As_Int32 (Find_Field (Parsed, 1)) = 10, "known field #1");
 620 +:       Assert (Protobuf.As_String (Find_Field (Parsed, 2)) = "known", "known field #2");
 621 +:       Assert (Count_Field (Parsed, 19_000) = 1, "unknown fixed field preserved");
 622 +:       Assert (Count_Field (Parsed, 29_000) = 1, "unknown varint field preserved");
 623 .:    end Test_Unknown_Fields_Stability;
