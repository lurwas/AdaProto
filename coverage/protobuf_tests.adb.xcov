1082 +:          AUnit.Test_Suites.Add_Test (Registered_Suite, New_Case ("truncated varint", Test_Truncated_Varint_Fails'Access));
1083 +:          AUnit.Test_Suites.Add_Test (Registered_Suite, New_Case ("unsupported group", Test_Unsupported_Group_Wire_Fails'Access));
1084 +:          AUnit.Test_Suites.Add_Test (Registered_Suite, New_Case ("wire mismatch", Test_Wire_Mismatch_Fails'Access));
