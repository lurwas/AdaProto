 963 .:    procedure Test_Chunked_Read_EOF is
 964 +:       S : Chunked_Input_Stream;
 965 +:       Item : Ada.Streams.Stream_Element_Array (1 .. 4);
 966 +:       Last : Ada.Streams.Stream_Element_Offset;
 967 .:    begin
 968 +:       S.Data := Ada.Strings.Unbounded.To_Unbounded_String ("");
 969 +:       S.Pos := 1;
 970 +:       S.Chunk_Size := 1;
 971 +:       Read (S, Item, Last);
 972 +:       Assert (Last = Item'First - 1, "empty stream read should report EOF");
 973 .:    end Test_Chunked_Read_EOF;
