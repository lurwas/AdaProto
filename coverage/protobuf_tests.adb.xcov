 451 +:             Protobuf.Add_Bool (B, 7, V_Bool);
 452 +:             Protobuf.Add_String (B, 8, V_Str);
 453 +:             Protobuf.Add_Packed_SInt32 (B, 9, (V_S32, -V_S32, Integer_32 (I)));
 454 .: 
 455 +:             Parsed := Protobuf.Deserialize_From_String (Protobuf.Serialize_To_String (B));
 456 +:             Assert (Protobuf.As_Int32 (Find_Field (Parsed, 1)) = V_I32, "random int32");
 457 +:             Assert (Protobuf.As_Int64 (Find_Field (Parsed, 2)) = V_I64, "random int64");
 458 +:             Assert (Protobuf.As_UInt32 (Find_Field (Parsed, 3)) = V_U32, "random uint32");
 459 +:             Assert (Protobuf.As_UInt64 (Find_Field (Parsed, 4)) = V_U64, "random uint64");
 460 +:             Assert (Protobuf.As_SInt32 (Find_Field (Parsed, 5)) = V_S32, "random sint32");
 461 +:             Assert (Protobuf.As_SInt64 (Find_Field (Parsed, 6)) = V_S64, "random sint64");
 462 +:             Assert (Protobuf.As_Bool (Find_Field (Parsed, 7)) = V_Bool, "random bool");
 463 +:             Assert (Protobuf.As_String (Find_Field (Parsed, 8)) = V_Str, "random string");
 464 .:          end;
 465 .:       end loop;
 466 .:    end Test_Randomized_Roundtrip;
