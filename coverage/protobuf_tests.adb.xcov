 910 +:               Character'Val (16#22#) &
 911 +:               Character'Val (16#33#) &
 912 +:               Character'Val (16#44#) &
 913 +:               Character'Val (16#55#) &
 914 +:               Character'Val (16#66#) &
 915 +:               Character'Val (16#77#));
