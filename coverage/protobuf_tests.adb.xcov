 330 +:       Assert (Protobuf.As_SInt32 (Find_Field (Fields, 5)) = -321, "sint32");
 331 +:       Assert (Protobuf.As_SInt64 (Find_Field (Fields, 6)) = -6_543_219_876_543, "sint64");
 332 +:       Assert (Protobuf.As_Bool (Find_Field (Fields, 7)), "bool");
