1013 .:    procedure Test_Packed_UInt64_And_SInt64 is
1014 +:       B : Protobuf.Message_Buffer;
1015 +:       Parsed : Protobuf.Parsed_Field_Vectors.Vector;
1016 .:    begin
1017 +:       Protobuf.Add_Packed_UInt64
1018 +:         (B,
1019 +:          1,
1020 +:          (0,
1021 +:           1,
1022 +:           127,
1023 +:           128,
1024 +:           16#FFFF_FFFF_FFFF_FFFF#));
1025 +:       Protobuf.Add_Packed_SInt64
1026 +:         (B,
1027 +:          2,
1028 +:          (-9_223_372_036_854_775_808,
1029 +:           -1,
1030 +:           0,
1031 +:           1,
1032 +:           9_223_372_036_854_775_807));
1033 .: 
1034 +:       Parsed := Protobuf.Parse_From_String (Protobuf.To_String (B));
1035 .: 
1036 .:       declare
1037 +:          U : constant Protobuf.UInt64_Array :=
1038 +:            Protobuf.Decode_Packed_UInt64 (Protobuf.As_Bytes (Find_Field (Parsed, 1)));
1039 +:          S : constant Protobuf.Int64_Array :=
1040 +:            Protobuf.Decode_Packed_SInt64 (Protobuf.As_Bytes (Find_Field (Parsed, 2)));
1041 .:       begin
1042 +:          Assert (U'Length = 5, "packed uint64 size");
1043 +:          Assert (U (1) = 0, "packed uint64 #1");
1044 +:          Assert (U (2) = 1, "packed uint64 #2");
1045 +:          Assert (U (3) = 127, "packed uint64 #3");
1046 +:          Assert (U (4) = 128, "packed uint64 #4");
1047 +:          Assert (U (5) = 16#FFFF_FFFF_FFFF_FFFF#, "packed uint64 #5");
1048 .: 
1049 +:          Assert (S'Length = 5, "packed sint64 size");
1050 +:          Assert (S (1) = -9_223_372_036_854_775_808, "packed sint64 #1");
1051 +:          Assert (S (2) = -1, "packed sint64 #2");
1052 +:          Assert (S (3) = 0, "packed sint64 #3");
1053 +:          Assert (S (4) = 1, "packed sint64 #4");
1054 +:          Assert (S (5) = 9_223_372_036_854_775_807, "packed sint64 #5");
1055 .:       end;
1056 .:    end Test_Packed_UInt64_And_SInt64;
1057 .: 
1058 .:    function Suite return AUnit.Test_Suites.Access_Test_Suite is
1059 .:    begin
1060 +:       if Registered_Suite = null then
