 517 .:    procedure Test_Malformed_Fuzz_Corpus is
 518 +:       State : Unsigned_64 := 16#1234_5678_9ABC_DEF0#;
 519 .:    begin
 520 +:       for I in 1 .. 500 loop
 521 .:          declare
 522 +:             Len : constant Natural := Natural (Next_Rand (State) mod 64);
 523 +:             S : String (1 .. (if Len = 0 then 1 else Len));
 524 +:             Failed_Ok : Boolean := False;
 525 .:          begin
 526 +:             if Len = 0 then
 527 -:                S (1) := Character'Val (0);
 528 .:             else
 529 +:                for J in 1 .. Len loop
 530 +:                   S (J) := Character'Val (Integer (Next_Rand (State) and 16#FF#));
 531 .:                end loop;
 532 .:             end if;
 533 .:             begin
 534 .:                declare
 535 +:                   Ignore : constant Protobuf.Parsed_Field_Vectors.Vector :=
 536 +:                     Protobuf.Parse_From_String (if Len = 0 then "" else S (1 .. Len));
 537 .:                begin
 538 -:                   null;
 539 .:                end;
 540 .:             exception
 541 .:                when Protobuf.Parse_Error =>
 542 +:                   Failed_Ok := True;
 543 .:                when others =>
 544 -:                   Assert (False, "unexpected exception in fuzz corpus");
 545 .:             end;
 546 .:             pragma Unreferenced (Failed_Ok);
 547 .:          end;
 548 .:       end loop;
 549 .:    end Test_Malformed_Fuzz_Corpus;
