 468 .:    procedure Test_Boundary_Value_Matrix is
 469 +:       B : Protobuf.Message_Buffer;
 470 +:       Parsed : Protobuf.Parsed_Field_Vectors.Vector;
 471 .:    begin
 472 +:       Protobuf.Add_Int32 (B, 1, Integer_32'First);
 473 +:       Protobuf.Add_Int32 (B, 1, Integer_32'Last);
 474 +:       Protobuf.Add_Int64 (B, 2, Integer_64'First);
 475 +:       Protobuf.Add_Int64 (B, 2, Integer_64'Last);
 476 +:       Protobuf.Add_UInt32 (B, 3, Unsigned_32'First);
 477 +:       Protobuf.Add_UInt32 (B, 3, Unsigned_32'Last);
 478 +:       Protobuf.Add_UInt64 (B, 4, Unsigned_64'First);
 479 +:       Protobuf.Add_UInt64 (B, 4, Unsigned_64'Last);
 480 +:       Protobuf.Add_SInt32 (B, 5, Integer_32'First);
 481 +:       Protobuf.Add_SInt32 (B, 5, Integer_32'Last);
 482 +:       Protobuf.Add_SInt64 (B, 6, Integer_64'First);
 483 +:       Protobuf.Add_SInt64 (B, 6, Integer_64'Last);
 484 +:       Protobuf.Add_Float (B, 7, Protobuf.Float32'First);
 485 +:       Protobuf.Add_Float (B, 7, Protobuf.Float32'Last);
 486 +:       Protobuf.Add_Double (B, 8, Protobuf.Float64'First);
 487 +:       Protobuf.Add_Double (B, 8, Protobuf.Float64'Last);
 488 .: 
 489 +:       Parsed := Protobuf.Parse_From_String (Protobuf.To_String (B));
 490 +:       Assert (Protobuf.As_Int32 (Find_Field (Parsed, 1, 1)) = Integer_32'First, "boundary int32 first");
 491 +:       Assert (Protobuf.As_Int32 (Find_Field (Parsed, 1, 2)) = Integer_32'Last, "boundary int32 last");
 492 +:       Assert (Protobuf.As_Int64 (Find_Field (Parsed, 2, 1)) = Integer_64'First, "boundary int64 first");
 493 +:       Assert (Protobuf.As_Int64 (Find_Field (Parsed, 2, 2)) = Integer_64'Last, "boundary int64 last");
 494 +:       Assert (Protobuf.As_UInt32 (Find_Field (Parsed, 3, 1)) = Unsigned_32'First, "boundary uint32 first");
 495 +:       Assert (Protobuf.As_UInt32 (Find_Field (Parsed, 3, 2)) = Unsigned_32'Last, "boundary uint32 last");
 496 +:       Assert (Protobuf.As_UInt64 (Find_Field (Parsed, 4, 1)) = Unsigned_64'First, "boundary uint64 first");
 497 +:       Assert (Protobuf.As_UInt64 (Find_Field (Parsed, 4, 2)) = Unsigned_64'Last, "boundary uint64 last");
 498 .:    end Test_Boundary_Value_Matrix;
