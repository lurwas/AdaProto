 240 .:    procedure Read
 241 .:      (Stream : in out Chunked_Input_Stream;
 242 .:       Item   : out Ada.Streams.Stream_Element_Array;
 243 .:       Last   : out Ada.Streams.Stream_Element_Offset) is
 244 +:       Source : constant String := Ada.Strings.Unbounded.To_String (Stream.Data);
 245 +:       Remaining : Natural := 0;
 246 +:       To_Copy : Natural := 0;
 247 .:    begin
 248 +:       if Stream.Pos > Source'Length then
 249 +:          Last := Item'First - 1;
 250 +:          return;
 251 .:       end if;
 252 +:       Remaining := Source'Length - Stream.Pos + 1;
 253 +:       To_Copy := Natural'Min (Natural (Item'Length), Natural'Min (Stream.Chunk_Size, Remaining));
 254 +:       for I in 0 .. To_Copy - 1 loop
 255 +:          Item (Item'First + Ada.Streams.Stream_Element_Offset (I)) :=
 256 +:            Ada.Streams.Stream_Element (Character'Pos (Source (Stream.Pos + I)));
 257 .:       end loop;
 258 +:       Stream.Pos := Stream.Pos + To_Copy;
 259 +:       Last := Item'First + Ada.Streams.Stream_Element_Offset (To_Copy) - 1;
 260 .:    end Read;
