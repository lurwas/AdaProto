 975 .:    procedure Test_Enum_And_Packed_Int64 is
 976 +:       B : Protobuf.Message_Buffer;
 977 +:       Parsed : Protobuf.Parsed_Field_Vectors.Vector;
 978 .:    begin
 979 +:       Protobuf.Add_Enum (B, 1, -42);
 980 +:       Protobuf.Add_Packed_Int64 (B, 2, (-9_223_372_036_854_775_808, -1, 0, 1, 9_223_372_036_854_775_807));
 981 +:       Parsed := Protobuf.Parse_From_String (Protobuf.To_String (B));
 982 .: 
 983 +:       Assert (Protobuf.As_Enum (Find_Field (Parsed, 1)) = -42, "enum value");
 984 .:       declare
 985 +:          Decoded : constant Protobuf.Int64_Array :=
 986 +:            Protobuf.Decode_Packed_Int64 (Protobuf.As_Bytes (Find_Field (Parsed, 2)));
 987 .:       begin
 988 +:          Assert (Decoded'Length = 5, "packed int64 size");
 989 +:          Assert (Decoded (1) = -9_223_372_036_854_775_808, "packed int64 #1");
 990 +:          Assert (Decoded (2) = -1, "packed int64 #2");
 991 +:          Assert (Decoded (3) = 0, "packed int64 #3");
 992 +:          Assert (Decoded (4) = 1, "packed int64 #4");
 993 +:          Assert (Decoded (5) = 9_223_372_036_854_775_807, "packed int64 #5");
 994 .:       end;
 995 .:    end Test_Enum_And_Packed_Int64;
 996 .: 
 997 .:    procedure Test_Stream_Serialization_Empty_Buffer is
 998 +:       package SIO renames Ada.Streams.Stream_IO;
 999 +:       Tmp : constant String := "tests/.tmp-stream-empty.bin";
1000 +:       File : SIO.File_Type;
1001 +:       B : Protobuf.Message_Buffer;
1002 .:    begin
1003 +:       SIO.Create (File, SIO.Out_File, Tmp);
1004 +:       Protobuf.Write_To_Stream (B, SIO.Stream (File));
1005 +:       SIO.Close (File);
1006 .: 
1007 +:       SIO.Open (File, SIO.In_File, Tmp);
1008 +:       Assert (Natural (SIO.Size (File)) = 0, "empty buffer should write zero bytes");
1009 +:       SIO.Close (File);
1010 +:       Ada.Directories.Delete_File (Tmp);
1011 .:    end Test_Stream_Serialization_Empty_Buffer;
