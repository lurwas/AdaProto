 584 .:    procedure Test_Cpp_Differential_Corpus is
 585 +:       Corpus : constant String := Fixture_Loader.Read_Fixture ("all_types_corpus.hex");
 586 +:       Line_Start : Positive := Corpus'First;
 587 +:       Seed : Unsigned_64 := 1;
 588 .:    begin
 589 +:       for I in Corpus'Range loop
 590 +:          if Corpus (I) = ASCII.LF then
 591 +:             if I > Line_Start then
 592 .:                declare
 593 +:                   Line : constant String := Corpus (Line_Start .. I - 1);
 594 +:                   Expected : constant String := Decode_Hex (Line);
 595 +:                   B : Protobuf.Message_Buffer;
 596 .:                begin
 597 +:                   Populate_Diff_Case_From_Seed (B, Seed);
 598 +:                   Assert (Protobuf.To_String (B) = Expected, "cpp differential mismatch seed=" & Img_U64 (Seed));
 599 +:                   Seed := Seed + 1;
 600 .:                end;
 601 .:             end if;
 602 +:             if I < Corpus'Last then
 603 +:                Line_Start := I + 1;
 604 .:             end if;
 605 .:          end if;
 606 .:       end loop;
 607 +:       Assert (Seed = 129, "corpus should contain 128 lines");
 608 .:    end Test_Cpp_Differential_Corpus;
