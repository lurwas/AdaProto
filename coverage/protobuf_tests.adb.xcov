 834 .:    procedure Test_Packed_Fixed32 is
 835 +:       B : Protobuf.Message_Buffer;
 836 +:       Fields : Protobuf.Parsed_Field_Vectors.Vector;
 837 .:    begin
 838 +:       Protobuf.Add_Packed_Fixed32 (B, 1, (16#0102_0304#, 16#DEAD_BEEF#));
 839 +:       Fields := Protobuf.Parse_From_String (Protobuf.To_String (B));
 840 .:       declare
 841 +:          Payload : constant String := Protobuf.As_Bytes (Find_Field (Fields, 1));
 842 .:       begin
 843 +:          Assert (Payload'Length = 8, "packed fixed32 payload length");
 844 +:          Assert (Character'Pos (Payload (1)) = 16#04# and Character'Pos (Payload (4)) = 16#01#, "little endian #1");
 845 +:          Assert (Character'Pos (Payload (5)) = 16#EF# and Character'Pos (Payload (8)) = 16#DE#, "little endian #2");
 846 .:       end;
 847 .:    end Test_Packed_Fixed32;
