 718 .:    procedure Test_Stream_Serialization is
 719 +:       package SIO renames Ada.Streams.Stream_IO;
 720 +:       Tmp : constant String := "tests/.tmp-stream.bin";
 721 +:       File : SIO.File_Type;
 722 +:       B : Protobuf.Message_Buffer;
 723 +:       Parsed : Protobuf.Parsed_Field_Vectors.Vector;
 724 .:    begin
 725 +:       Protobuf.Add_String (B, 1, "stream");
 726 +:       Protobuf.Add_Int32 (B, 2, 42);
 727 .: 
 728 +:       SIO.Create (File, SIO.Out_File, Tmp);
 729 +:       Protobuf.Write_To_Stream (B, SIO.Stream (File));
 730 +:       SIO.Close (File);
 731 .: 
 732 +:       SIO.Open (File, SIO.In_File, Tmp);
 733 +:       Parsed := Protobuf.Parse_From_Stream (SIO.Stream (File), Natural (SIO.Size (File)));
 734 +:       SIO.Close (File);
 735 +:       Ada.Directories.Delete_File (Tmp);
 736 .: 
 737 +:       Assert (Protobuf.As_String (Find_Field (Parsed, 1)) = "stream", "stream string");
 738 +:       Assert (Protobuf.As_Int32 (Find_Field (Parsed, 2)) = 42, "stream int");
 739 .:    end Test_Stream_Serialization;
