 695 .:    procedure Test_Benchmark_Regression_Guard is
 696 .:       use Ada.Calendar;
 697 +:       Start_Time : Time;
 698 +:       End_Time : Time;
 699 +:       Iterations : constant Positive := 20_000;
 700 .:    begin
 701 +:       Start_Time := Clock;
 702 +:       for I in 1 .. Iterations loop
 703 .:          declare
 704 +:             B : Protobuf.Message_Buffer;
 705 +:             Parsed : Protobuf.Parsed_Field_Vectors.Vector;
 706 .:          begin
 707 +:             Protobuf.Add_Int32 (B, 1, Integer_32 (I));
 708 +:             Protobuf.Add_UInt64 (B, 2, Unsigned_64 (I) * 17);
 709 +:             Protobuf.Add_String (B, 3, "bench");
 710 +:             Parsed := Protobuf.Parse_From_String (Protobuf.To_String (B));
 711 +:             Assert (Protobuf.As_Int32 (Find_Field (Parsed, 1)) = Integer_32 (I), "bench guard parse");
 712 .:          end;
 713 .:       end loop;
 714 +:       End_Time := Clock;
 715 +:       Assert (End_Time - Start_Time < 30.0, "benchmark guard exceeded threshold");
 716 .:    end Test_Benchmark_Regression_Guard;
