 678 .:    procedure Test_Stream_Chunking is
 679 +:       B : Protobuf.Message_Buffer;
 680 +:       Parsed : Protobuf.Parsed_Field_Vectors.Vector;
 681 +:       S : aliased Chunked_Input_Stream;
 682 .:    begin
 683 +:       Populate_All_Types (B);
 684 .:       declare
 685 +:          Encoded : constant String := Protobuf.To_String (B);
 686 .:       begin
 687 +:          S.Data := Ada.Strings.Unbounded.To_Unbounded_String (Encoded);
 688 +:          S.Pos := 1;
 689 +:          S.Chunk_Size := 3;
 690 +:          Parsed := Protobuf.Parse_From_Stream (S'Access, Encoded'Length);
 691 .:       end;
 692 +:       Assert_All_Types_Fields (Parsed);
 693 .:    end Test_Stream_Chunking;
