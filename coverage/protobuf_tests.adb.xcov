 883 .:    procedure Test_Truncated_Fixed32_Fails is
 884 +:       Failed : Boolean := False;
 885 +:       Ignore : Protobuf.Parsed_Field_Vectors.Vector;
 886 .:    begin
 887 .:       begin
 888 +:          Ignore :=
 889 +:            Protobuf.Parse_From_String
 890 +:              (Character'Val (16#0D#) &
 891 +:               Character'Val (16#11#) &
 892 +:               Character'Val (16#22#) &
 893 +:               Character'Val (16#33#));
 894 .:       exception
 895 .:          when Protobuf.Parse_Error =>
 896 +:             Failed := True;
 897 .:       end;
 898 +:       Assert (Failed, "truncated fixed32 must fail");
 899 .:    end Test_Truncated_Fixed32_Fails;
