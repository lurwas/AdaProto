1094 +:          AUnit.Test_Suites.Add_Test (Registered_Suite, New_Case ("decode hex odd length", Test_Decode_Hex_Odd_Length_Fails'Access));
1095 +:          AUnit.Test_Suites.Add_Test (Registered_Suite, New_Case ("chunked read eof", Test_Chunked_Read_EOF'Access));
