1062 +:          AUnit.Test_Suites.Add_Test (Registered_Suite, New_Case ("empty message", Test_Empty_Message_Encodes_Empty'Access));
1063 +:          AUnit.Test_Suites.Add_Test (Registered_Suite, New_Case ("all scalar encodings", Test_All_Scalar_Encodings'Access));
1064 +:          AUnit.Test_Suites.Add_Test (Registered_Suite, New_Case ("string alias api", Test_Serialize_Deserialize_String_Aliases'Access));
1065 +:          AUnit.Test_Suites.Add_Test (Registered_Suite, New_Case ("randomized roundtrip", Test_Randomized_Roundtrip'Access));
1066 +:          AUnit.Test_Suites.Add_Test (Registered_Suite, New_Case ("boundary matrix", Test_Boundary_Value_Matrix'Access));
1067 +:          AUnit.Test_Suites.Add_Test (Registered_Suite, New_Case ("large payload stress", Test_Large_Payload_Stress'Access));
1068 +:          AUnit.Test_Suites.Add_Test (Registered_Suite, New_Case ("malformed fuzz", Test_Malformed_Fuzz_Corpus'Access));
1069 +:          AUnit.Test_Suites.Add_Test (Registered_Suite, New_Case ("malformed corpus fixture", Test_Malformed_Corpus_Fixture'Access));
1070 +:          AUnit.Test_Suites.Add_Test (Registered_Suite, New_Case ("cpp differential corpus", Test_Cpp_Differential_Corpus'Access));
1071 +:          AUnit.Test_Suites.Add_Test (Registered_Suite, New_Case ("stream serialization", Test_Stream_Serialization'Access));
