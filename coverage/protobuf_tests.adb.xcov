 551 .:    procedure Test_Malformed_Corpus_Fixture is
 552 +:       Corpus : constant String := Fixture_Loader.Read_Fixture ("malformed_corpus.hex");
 553 +:       Line_Start : Positive := Corpus'First;
 554 .:    begin
 555 +:       for I in Corpus'Range loop
 556 +:          if Corpus (I) = ASCII.LF then
 557 +:             if I > Line_Start then
 558 .:                declare
 559 +:                   Line : constant String := Corpus (Line_Start .. I - 1);
 560 +:                   Data : constant String := Decode_Hex (Line);
 561 .:                begin
 562 .:                   begin
 563 .:                      declare
 564 +:                         Ignore : constant Protobuf.Parsed_Field_Vectors.Vector :=
 565 +:                           Protobuf.Parse_From_String (Data);
 566 .:                      begin
 567 -:                         null;
 568 .:                      end;
 569 .:                   exception
 570 .:                      when Protobuf.Parse_Error =>
 571 +:                         null;
 572 .:                      when others =>
 573 -:                         Assert (False, "unexpected exception in malformed corpus fixture");
 574 .:                   end;
 575 .:                end;
 576 .:             end if;
 577 +:             if I < Corpus'Last then
 578 +:                Line_Start := I + 1;
 579 .:             end if;
 580 .:          end if;
 581 .:       end loop;
 582 .:    end Test_Malformed_Corpus_Fixture;
