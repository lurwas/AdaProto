 625 .:    procedure Test_Packed_Unpacked_Equivalence is
 626 +:       Packed_B : Protobuf.Message_Buffer;
 627 +:       Unpacked_B : Protobuf.Message_Buffer;
 628 +:       Packed_Parsed : Protobuf.Parsed_Field_Vectors.Vector;
 629 +:       Unpacked_Parsed : Protobuf.Parsed_Field_Vectors.Vector;
 630 +:       Packed_Values : Protobuf.Int32_Array (1 .. 3) := (-10, 0, 25);
 631 .:    begin
 632 +:       Protobuf.Add_Packed_Int32 (Packed_B, 1, Packed_Values);
 633 +:       Protobuf.Add_Int32 (Unpacked_B, 1, -10);
 634 +:       Protobuf.Add_Int32 (Unpacked_B, 1, 0);
 635 +:       Protobuf.Add_Int32 (Unpacked_B, 1, 25);
 636 .: 
 637 +:       Packed_Parsed := Protobuf.Parse_From_String (Protobuf.To_String (Packed_B));
 638 +:       Unpacked_Parsed := Protobuf.Parse_From_String (Protobuf.To_String (Unpacked_B));
 639 .: 
 640 .:       declare
 641 +:          Decoded_Packed : constant Protobuf.Int32_Array :=
 642 +:            Protobuf.Decode_Packed_Int32 (Protobuf.As_Bytes (Find_Field (Packed_Parsed, 1)));
 643 .:       begin
 644 +:          Assert (Decoded_Packed'Length = 3, "packed len");
 645 +:          Assert (Decoded_Packed (1) = Protobuf.As_Int32 (Find_Field (Unpacked_Parsed, 1, 1)), "eq #1");
 646 +:          Assert (Decoded_Packed (2) = Protobuf.As_Int32 (Find_Field (Unpacked_Parsed, 1, 2)), "eq #2");
 647 +:          Assert (Decoded_Packed (3) = Protobuf.As_Int32 (Find_Field (Unpacked_Parsed, 1, 3)), "eq #3");
 648 .:       end;
 649 .:    end Test_Packed_Unpacked_Equivalence;
 650 .: 
 651 .:    procedure Test_Public_Packed_Decode_Helpers is
 652 +:       B : Protobuf.Message_Buffer;
 653 +:       Parsed : Protobuf.Parsed_Field_Vectors.Vector;
 654 .:    begin
 655 +:       Protobuf.Add_Packed_Bool (B, 1, (True, False, True));
 656 +:       Protobuf.Add_Packed_Fixed64 (B, 2, (16#0102_0304_0506_0708#, 16#F0E0_D0C0_B0A0_9080#));
 657 +:       Protobuf.Add_Packed_SFixed32 (B, 3, (-1, 0, 1));
 658 +:       Protobuf.Add_Packed_Float (B, 4, (1.25, -2.5));
 659 +:       Protobuf.Add_Packed_Double (B, 5, (3.25, -9.5));
 660 .: 
 661 +:       Parsed := Protobuf.Parse_From_String (Protobuf.To_String (B));
 662 .: 
 663 .:       declare
 664 +:          V1 : constant Protobuf.Bool_Array := Protobuf.Decode_Packed_Bool (Protobuf.As_Bytes (Find_Field (Parsed, 1)));
 665 +:          V2 : constant Protobuf.Fixed64_Array := Protobuf.Decode_Packed_Fixed64 (Protobuf.As_Bytes (Find_Field (Parsed, 2)));
 666 +:          V3 : constant Protobuf.SFixed32_Array := Protobuf.Decode_Packed_SFixed32 (Protobuf.As_Bytes (Find_Field (Parsed, 3)));
 667 +:          V4 : constant Protobuf.Float_Array := Protobuf.Decode_Packed_Float (Protobuf.As_Bytes (Find_Field (Parsed, 4)));
 668 +:          V5 : constant Protobuf.Double_Array := Protobuf.Decode_Packed_Double (Protobuf.As_Bytes (Find_Field (Parsed, 5)));
 669 .:       begin
 670 +:          Assert (V1'Length = 3 and V1 (1) and (not V1 (2)) and V1 (3), "decode packed bool");
 671 +:          Assert (V2'Length = 2 and V2 (1) = 16#0102_0304_0506_0708# and V2 (2) = 16#F0E0_D0C0_B0A0_9080#, "decode packed fixed64");
 672 +:          Assert (V3'Length = 3 and V3 (1) = -1 and V3 (2) = 0 and V3 (3) = 1, "decode packed sfixed32");
 673 +:          Assert (V4'Length = 2 and abs (V4 (1) - 1.25) < 0.0001 and abs (V4 (2) - (-2.5)) < 0.0001, "decode packed float");
 674 +:          Assert (V5'Length = 2 and abs (V5 (1) - 3.25) < 0.0000001 and abs (V5 (2) - (-9.5)) < 0.0000001, "decode packed double");
 675 .:       end;
 676 .:    end Test_Public_Packed_Decode_Helpers;
