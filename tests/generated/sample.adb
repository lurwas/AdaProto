                  declare
                     A : constant Protobuf.Int32_Array := Protobuf.Decode_Packed_Int32 (Protobuf.As_Bytes (Item));
                  begin
                     for V of A loop Result.Palette.Append (V); end loop;
                  end;
               else
                  Result.Palette.Append (Protobuf.As_Int32 (Item));
               end if;
            when others => null;
         end case;
      end loop;
      return Result;
